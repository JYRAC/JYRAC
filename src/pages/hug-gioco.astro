---
// 1. カードデータやディスカッションの問いをAstroのデータ層として定義
const CARDS = [
  { id: 1, c: 'dis', txt: '避難所に指定された学校の体育館。外は激しい雨と風。', e: '⛈️' },
  { id: 2, c: 'dis', txt: '夜間に大きな地震が発生。周辺一帯が停電している。', e: '🌑' },
  { id: 3, c: 'dis', txt: '真冬の寒波のなか地震が発生。暖房が効かない。', e: '❄️' },
  { id: 4, c: 'dis', txt: '台風による大雨で、近くの河川の水位が警戒レベルに。', e: '🌊' },
  { id: 5, c: 'time', txt: '発災から「3時間後」。最初の避難者が次々と押し寄せる。', e: '⏳' },
  { id: 6, c: 'time', txt: '発災から「24時間後（1日目）」。仮設トイレが届く。', e: '🌅' },
  { id: 7, c: 'time', txt: '発災から「3日後（72時間）」。救援物資の第一陣が到着。', e: '📅' },
  { id: 8, c: 'fac', txt: '体育館のほか、教室3室と多目的ホールが使用可能。', e: '🏫' },
  { id: 9, c: 'fac', txt: '学校の受水槽が生きており、水は出るが流せない。', e: '🚰' },
  { id: 10, c: 'fac', txt: '備蓄倉庫からアルファ米300食と毛布50枚を発見。', e: '📦' },
  { id: 11, c: 'peo', txt: '乳幼児を連れた母親。授乳スペースを求めている。', e: '👶' },
  { id: 12, c: 'peo', txt: '車椅子の高齢者と、そのお世話をする家族。', e: '👨‍🦽' },
  { id: 13, c: 'peo', txt: '日本語が苦手な外国人の家族（大人2人、子ども1人）。', e: '🗣️' },
  { id: 14, c: 'peo', txt: 'ペット（大型犬）を連れて避難してきた飼い主。', e: '🐕' },
  { id: 15, c: 'peo', txt: '修学旅行中の高校生グループ30名が避難を求めてきた。', e: '🎒' }
];

const DISCUSSIONS = {
  t: ['マンホールトイレや仮設トイレをどこに設置するか？', '誰を優先して使ってもらうルールにするか？', 'トイレの清掃やゴミ出しの担当をどう決めるか？'],
  k: ['炊き出しや物資の配布場所をどこに設けるか？', 'アレルギーや宗教上の配慮が必要な人への対応は？', '貴重な水や燃料をどう管理・節約するか？'],
  b: ['通路を確保しつつ、プライベート空間をどう作るか？', '高齢者や要配慮者のベッド位置をどこにするか？', '体育館の床の冷たさや硬さを防ぐ工夫は？']
};

const CH_CARDS = [
  { id: 'ch1', c: 'con', txt: '避難所内の連絡・情報共有をどう行うか？', e: '📢' },
  { id: 'ch2', c: 'con', txt: '外部（役場や救急）との通信手段の確保は？', e: '📱' },
  { id: 'ch3', c: 'sup', txt: '届いた物資の仕分け・管理の担当者をどうするか？', e: '🤝' },
  { id: 'ch4', c: 'sup', txt: '避難者同士のトラブル（騒音・ペット等）の対応は？', e: '⚡' }
];
---
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HUG Gioco — TKB型避難所運営ディスカッションゲーム</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Baloo+2:wght@600;700;800&display=swap" rel="stylesheet">

<style is:global>
  :root {
    --primary: #009aa6; --primary-light: #00d2e0; --navy: #002b54; --navy-light: #0a3d6d;
    --green: #2E9E4F; --green-deep: #1f7d3c; --red: #E01E2B; --red-deep: #b8161f; --sky: #4AA9E0; --sky-soft: #DDEEFA; --sun: #FFD23F;
    --ink: #233047; --ink-soft: #5b6779; --line: rgba(0, 154, 166, 0.2); --shadow: 0 10px 24px rgba(27,58,140,.06); --radius: 24px;
    --panel-bg: rgba(255, 255, 255, 0.90);
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  body{
    font-family:'Zen Maru Gothic',system-ui,sans-serif; background: fixed linear-gradient(135deg, #e3f6f7 0%, #ffffff 50%, #f4fafb 100%); color:var(--ink); line-height:1.75; margin:0; padding:0;
  }
  header.site{ position:sticky; top:0; z-index:50; background:rgba(255,255,255,.92); backdrop-filter:blur(8px); border-bottom:2px solid var(--primary); padding:12px 20px; display:flex; align-items:center; gap:12px; box-shadow:0 4px 14px rgba(0,154,166,.05); }
  header.site .titles { display:flex; flex-direction:column; line-height:1.2; }
  header.site .titles b{ font-weight:900; font-size:1.25rem; color:var(--navy); }
  header.site .titles span{ font-size:.72rem; color:var(--primary); font-weight:700; letter-spacing: 0.05em; }
  header.site .nav-spacer{ flex:1; }
  
  .btn-back-to-site { font-weight:700; font-size:.85rem; color:var(--primary); text-decoration:none; background:#fff; border:2px solid var(--primary); padding:6px 16px; border-radius:999px; transition:.2s; display:inline-flex; align-items:center; gap:6px; }
  .btn-back-to-site:hover { background:var(--primary); color:#fff; }

  main{ max-width:1000px; margin:0 auto; padding:30px 20px 90px; }
  
  /* ボタンの新しいトーン＆マナー（ネイビーグラデーション） */
  .btn{ font-weight:800; border:none; cursor:pointer; border-radius:999px; padding:16px 36px; font-size:1.1rem; color:#fff; background:linear-gradient(135deg, var(--navy-light) 0%, var(--navy) 100%); box-shadow:0 6px 0 #00152b, 0 12px 24px rgba(0,43,84,.25); transition:transform .08s ease, box-shadow .08s ease; display:inline-flex; align-items:center; gap:10px; justify-content:center; }
  .btn:active{ transform:translateY(4px); box-shadow:0 2px 0 #00152b, 0 6px 12px rgba(0,43,84,.2); }
  .btn.green{ background:linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%); box-shadow:0 6px 0 #135226,0 12px 22px rgba(46,158,79,.25); }
  .btn.red{ background:linear-gradient(135deg, var(--red) 0%, var(--red-deep) 100%); box-shadow:0 6px 0 #8c1119,0 12px 22px rgba(224,30,43,.25); }
  .btn.sky{ background:var(--sky); box-shadow:0 6px 0 #2b87bd,0 12px 22px rgba(74,169,224,.25); }
  .btn.sun{ background:var(--sun); color:var(--navy); box-shadow:0 6px 0 #e0b325,0 12px 22px rgba(255,210,63,.3); }
  .btn.ghost{ background:#fff; color:var(--navy); border:2px solid var(--navy); box-shadow:0 6px 0 rgba(0,43,84,.1); }
  .btn.small{ padding:11px 22px; font-size:.95rem; }
  .btn.big{ padding:22px 50px; font-size:1.3rem; letter-spacing: 0.05em; }
  .btn:disabled{ opacity:.4; cursor:not-allowed; transform:none !important; box-shadow:none !important; }

  .view{ display:none; animation:pop .4s ease; }
  .view.active{ display:block; }
  @keyframes pop{ from{opacity:0; transform:translateY(12px);} to{opacity:1; transform:none;} }
  
  /* ミニマル化された美しいスタート画面レイアウト */
  .start-card { background: var(--panel-bg); border-radius: var(--radius); border: 2px solid var(--line); padding: 45px 30px; box-shadow: var(--shadow); backdrop-filter: blur(10px); text-align: center; max-width: 720px; margin: 40px auto; }
  .start-card h1 { font-size: clamp(2rem, 6vw, 2.75rem); color: var(--navy); font-weight: 900; margin: 0 0 10px 0; }
  .start-card .subtitle { color: var(--primary); font-size: clamp(1rem, 3vw, 1.2rem); font-weight: 700; letter-spacing: 0.05em; margin-bottom: 25px; }
  .start-card .description { font-size: 1rem; color: var(--ink-soft); max-width: 540px; margin: 0 auto 40px; line-height: 1.8; text-align: left; background: #ffffff; padding: 20px 24px; border-radius: 16px; border: 1px solid rgba(0,0,0,0.05); }

  .screen-head h2 { font-size: 1.6rem; color: var(--navy); font-weight: 900; margin-top: 0; margin-bottom: 20px; border-left: 6px solid var(--primary); padding-left: 12px; }
  .situation{ background: linear-gradient(135deg, var(--navy-light) 0%, var(--navy) 100%); color:#fff; border-radius:var(--radius); padding:24px 26px; margin:6px 0 20px; box-shadow:0 12px 30px rgba(0,43,84,.15); }
  .situation .lbl{ font-size:.9rem; font-weight:800; opacity:.85; letter-spacing: 0.05em; }
  .situation p{ font-size:clamp(1.05rem, 3vw, 1.25rem); font-weight:700; margin:.6em 0 0; line-height: 1.6; }

  .cards{ display:grid; gap:16px; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); margin: 25px 0; }
  .gcard{ position:relative; background:#fff; border-radius:20px; padding:20px 18px; box-shadow:var(--shadow); border: 1px solid rgba(0,0,0,0.04); border-top:8px solid var(--primary); overflow:hidden; transition: transform .2s ease; }
  .gcard .cat{ font-size:.75rem; font-weight:800; opacity:.85; letter-spacing: 0.05em; margin-bottom: 6px; }
  .gcard .txt{ font-weight:700; font-size:1.05rem; line-height: 1.5; color: var(--navy); }
  .gcard .emoji{ font-size:1.8rem; display: block; margin-bottom: 12px; }
  
  .c-dis{ border-top-color:var(--red); } .c-dis .cat{ color:var(--red); }
  .c-time{ border-top-color:var(--sky); } .c-time .cat{ color:var(--sky); }
  .c-fac{ border-top-color:var(--navy); } .c-fac .cat{ color:var(--navy); }
  .c-peo{ border-top-color:var(--sun); } .c-peo .cat{ color:#d4a017; }
  .c-con{ border-top-color:#7a5cc0; } .c-con .cat{ color:#7a5cc0; }
  .c-sup{ border-top-color:var(--green); } .c-sup .cat{ color:var(--green); }

  .q-groups{ display:grid; gap:20px; grid-template-columns:1fr; margin:20px 0; }
  @media(min-width:760px){ .q-groups{ grid-template-columns:1fr 1fr 1fr; } }
  .q-card{ background:#fff; border-radius:var(--radius); padding:22px; box-shadow:var(--shadow); border-top:7px solid var(--sky); border-left: 1px solid rgba(0,0,0,0.03); border-right: 1px solid rgba(0,0,0,0.03); border-bottom: 1px solid rgba(0,0,0,0.03); }
  .q-card.a{ border-top-color:var(--green); } .q-card.b{ border-top-color:var(--red); } .q-card.c{ border-top-color:var(--sun); }
  .q-card h4{ margin:.1em 0 .8em; font-size:1.15rem; font-weight: 900; color: var(--navy); }
  .q-card ul{ margin:0; padding:0; list-style:none; }
  .q-card li{ font-size:.98rem; font-weight: 700; color:var(--ink); line-height: 1.6; }

  .section-label{ font-weight:800; color:var(--navy); margin:35px 0 15px; font-size: 1.15rem; display: flex; align-items: center; gap: 8px; }
  .section-label .pill{ background:var(--primary); color:#fff; border-radius:6px; font-size:.75rem; padding:4px 10px; font-weight: 900; }
  .memo-grid{ display:grid; gap:20px; grid-template-columns:1fr; margin-bottom: 30px; }
  @media(min-width:720px){ .memo-grid{ grid-template-columns:1fr 1fr; } }
  .memo{ background:#fff; border-radius:var(--radius); padding:20px; box-shadow:var(--shadow); border: 1px solid rgba(0,0,0,0.04); border-left:8px solid var(--navy); }
  .memo.m1{ border-left-color:var(--red); } .memo.m2{ border-left-color:var(--sun); }
  .memo.m3{ border-left-color:var(--sky); } .memo.m4{ border-left-color:var(--green); }
  .memo.m5{ border-left-color:#7a5cc0; }
  .memo label{ font-weight:800; color:var(--navy); display:block; margin-bottom:12px; font-size: .98rem; }
  .memo textarea{ width:100%; border:2px solid rgba(0, 154, 166, 0.15); border-radius:16px; padding:14px; font-family:inherit; font-size:1rem; resize:vertical; min-height:100px; background:#fafdfd; transition: border-color 0.2s; }
  .memo textarea:focus { outline: none; border-color: var(--primary); background: #fff; }

  .review-box{ background:#fff; border-radius:var(--radius); padding:30px; box-shadow: 0 15px 40px rgba(0,43,84,.08); border:2px solid var(--navy); }
  .r-item{ border-bottom:2px dashed rgba(0,0,0,0.06); padding:18px 0; }
  .r-item:last-child { border-bottom: none; }
  .r-item h5{ color:var(--navy); margin:0 0 8px; font-size:1.1rem; font-weight: 900; }
  .r-item .content{ white-space:pre-wrap; font-weight: 500; font-size: 1rem; color: var(--ink); }
  .r-item .empty{ color:#b7bdc7; font-style:italic; }

  .final-actions{ display:flex; gap:14px; flex-wrap:wrap; justify-content:center; margin-top:35px; }
  .footer-note{ text-align:center; color:var(--ink-soft); font-size:.85rem; margin-top:50px; padding:20px; background:rgba(255,255,255,0.6); border-radius:16px; border: 1px solid rgba(0,0,0,0.03); }
  .toast{ position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(30px); background:var(--navy); color:#fff; padding:13px 28px; border-radius:999px; font-weight:800; opacity:0; pointer-events:none; transition:.3s; z-index:200; box-shadow: 0 10px 25px rgba(0,0,0,0.2); }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  @media(max-width:520px){ .btn-back-to-site { font-size: .75rem; padding: 4px 12px; } .start-card { padding: 30px 16px; } .btn.big { padding: 18px 32px; font-size: 1.15rem; } }
  @media print{ .final-actions, .btn, .footer-note, header.site { display:none !important; } .view{ display:none !important; } .view#view-4{ display:block !important; } .review-box { border: none; padding: 0; box-shadow: none; } }
</style>
</head>
<body>

<header class="site">
  <div class="titles"><b>HUG Gioco</b><span>TKB-STYLE EVACUATION SHELTER DISCUSSION GAME</span></div>
  <div class="nav-spacer"></div>
  <a href="/gioco" class="btn-back-to-site">JYRACサイトに戻る ➔</a>
</header>

<main>
  <div id="view-1" class="view active">
    <div class="start-card">
      <h1>HUG Gioco</h1>
      <div class="subtitle">ふりかえりシート作成ツール</div>
      
      <div class="description">
        避難所運営で重要となる<strong>TKB（トイレ・キッチン・ベッド）</strong>に焦点を当てたディスカッション用状況生成ツールです。<br><br>
        「🎲 カードを引く」ボタンを押すと、災害状況、経過時間、施設の設備、そして特別な配慮が必要な避難者のシチュエーションが自動で組み合わされます。
      </div>

      <div style="margin:20px 0;">
        <button id="btn-draw" class="btn big">🎲 カードを引いて状況を作る</button>
      </div>

      <div id="sit-cards" class="cards"></div>

      <div style="text-align:center; margin-top:40px;">
        <button id="btn-next-step1" class="btn green" disabled>次へ進む（課題を見つける） ➔</button>
      </div>
    </div>
  </div>

  <div id="view-2" class="view">
    <div class="screen-head"><h2>STEP 2: TKBの課題に向き合う</h2></div>
    <div class="situation"><div class="lbl">現在のシチュエーション</div><p id="step2-sit-text"></p></div>
    
    <div id="q-cards-box" class="q-groups"></div>

    <div class="section-label"><span class="pill">MEMO</span> ディスカッション意見を記録しよう</div>
    <div class="memo-grid">
      <div class="memo m1">
        <label>① 今回の状況で「見つかった課題」は？</label>
        <textarea data-memo="issues" placeholder="例：停電でトイレが真っ暗、車椅子の人の動線など"></textarea>
      </div>
      <div class="memo m2">
        <label>② 「特に配慮が必要な人」は誰？</label>
        <textarea data-memo="care" placeholder="例：授乳場所がない母親、外国籍の家族など"></textarea>
      </div>
    </div>
    <div class="final-actions">
      <button id="btn-back-step2" class="btn ghost small">🔀 状況を引き直す</button>
      <button id="btn-next-step2" class="btn green">次へ進む（チャレンジ発生） ➔</button>
    </div>
  </div>

  <div id="view-3" class="view">
    <div class="screen-head"><h2>STEP 3: 突然のトラブル・運営課題</h2></div>
    <div id="ch-cards-box" class="cards" style="margin-bottom:30px;"></div>
    
    <div class="memo-grid">
      <div class="memo m3">
        <label>③ 混乱を防ぐために「今すぐ必要な対応」は？</label>
        <textarea data-memo="now" placeholder="例：高校生に手伝ってもらう、案内を急ぎ掲示するなど"></textarea>
      </div>
      <div class="memo m4">
        <label>④ 普段の生活から「事前に準備すべきこと」は？</label>
        <textarea data-memo="prep" placeholder="例：学校の備蓄品見直し、防災訓練の実施など"></textarea>
      </div>
    </div>
    <div class="final-actions">
      <button id="btn-back-step3" class="btn ghost small">⬅ 戻る</button>
      <button id="btn-next-step3" class="btn green">シートをまとめて完成！ ➔</button>
    </div>
  </div>

  <div id="view-4" class="view">
    <div class="screen-head"><h2>HUG Gioco ふりかえりシート</h2></div>
    <div class="review-box">
      <div class="r-item"><h5>シチュエーション（設定条件）</h5><div id="rSit" class="content"></div></div>
      <div class="r-item"><h5>Q1. 今回の状況で「見つかった課題」</h5><div class="content" data-r="issues"></div></div>
      <div class="r-item"><h5>Q2. 「特に配慮が必要な人」への気づき</h5><div class="content" data-r="care"></div></div>
      <div class="r-item"><h5>Q3. トラブルを防ぐために「今すぐ必要な対応」</h5><div class="content" data-r="now"></div></div>
      <div class="r-item"><h5>Q4. 防災のために「事前に準備・備蓄すべきこと」</h5><div class="content" data-r="prep"></div></div>
      <div class="r-item">
        <h5>Q5. 学校・自治体・地域への提案・アイデア</h5>
        <div class="memo m5" style="border:none; padding:0; box-shadow:none;">
          <textarea data-memo="propose" placeholder="例：地域の防災訓練に子どもを巻き込むアイデアなど" style="min-height:100px; margin-top:8px;"></textarea>
        </div>
      </div>
    </div>
    <div class="final-actions">
      <button id="btn-back-step4" class="btn ghost small">⬅ 修正する</button>
      <button id="btn-copy" class="btn sun">📋 テキストをコピーする</button>
      <button id="btn-print" class="btn sky">🖨️ A4用紙に印刷する</button>
      <button id="btn-restart" class="btn red">🔄 もう一度遊ぶ</button>
    </div>
    <div class="footer-note"><b>HUG Gioco (グロッコ)</b> — TKB型避難所運営ディスカッションゲーム<br>協力：日本若者防災復興協会（JYRAC）</div>
  </div>
</main>

<div id="toast" class="toast"></div>

<script is:inline define:vars={{ CARDS, DISCUSSIONS, CH_CARDS }}>
  let DECK = [...CARDS];
  let CURRENT = null;

  const $ = sel => document.querySelector(sel);
  const $$ = sel => document.querySelectorAll(sel);

  function showView(id){
    $$('.view').forEach(v => v.classList.remove('active'));
    $(`#view-${id}`).classList.add('active');
    window.scrollTo(0,0);
  }

  function makeCardHtml(c){
    const catMaps = {dis:'災害・状況',time:'経過時間',fac:'施設・物資',peo:'避難者',con:'運営・情報',sup:'支援・対話'};
    const catName = catMaps[c.c] || c.c;
    return `<div class="gcard c-${c.c}"><span class="emoji">${c.e}</span><div class="cat">${catName}</div><div class="txt">${c.txt}</div></div>`;
  }

  function sample(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

  function startTool(){
    DECK = [...CARDS]; CURRENT = null;
    $$('textarea[data-memo]').forEach(t => t.value = '');
    $('#rSit').textContent = '';
    $('#sit-cards').innerHTML = '';
    $('#btn-next-step1').disabled = true;
    showView(1);
  }

  function drawSituation(){
    const dis = DECK.filter(c => c.c === 'dis'), time = DECK.filter(c => c.c === 'time'), fac = DECK.filter(c => c.c === 'fac'), peo = DECK.filter(c => c.c === 'peo');
    const c1 = sample(dis), c2 = sample(time), c3 = sample(fac);
    let p1 = sample(peo), p2 = sample(peo);
    while(p1.id === p2.id) p2 = sample(peo);
    CURRENT = { dis:c1, time:c2, fac:c3, p1, p2 };

    $('#sit-cards').innerHTML = makeCardHtml(c1) + makeCardHtml(c2) + makeCardHtml(c3) + makeCardHtml(p1) + makeCardHtml(p2);
    $('#btn-next-step1').disabled = false;
    
    // カード描画時に少しスクロール
    setTimeout(() => {
      $('#sit-cards').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  function situationText(cur){
    return `【${cur.dis.txt}】のなか、発災から【${cur.time.txt}】が経過。避難所環境は【${cur.fac.txt}】。そこへ【${cur.p1.txt}】や【${cur.p2.txt}】が避難しています。`;
  }

  function buildStep2(){
    $('#step2-sit-text').innerHTML = `状況：<b>${CURRENT.dis.txt}</b><br>時間：<b>${CURRENT.time.txt}</b><br>施設：<b>${CURRENT.fac.txt}</b><br>避難者：<b>${CURRENT.p1.txt}</b> ／ <b>${CURRENT.p2.txt}</b>`;
    $('#q-cards-box').innerHTML = `
      <div class="q-card a"><h4>🚾 T トイレの課題</h4><ul><li>${sample(DISCUSSIONS.t)}</li></ul></div>
      <div class="q-card b"><h4>🍳 K キッチンの課題</h4><ul><li>${sample(DISCUSSIONS.k)}</li></ul></div>
      <div class="q-card c"><h4>🛏️ B ベッドの課題</h4><ul><li>${sample(DISCUSSIONS.b)}</li></ul></div>`;
    showView(2);
  }

  function buildStep3(){
    let ch1 = sample(CH_CARDS), ch2 = sample(CH_CARDS);
    while(ch1.id === ch2.id) ch2 = sample(CH_CARDS);
    $('#ch-cards-box').innerHTML = makeCardHtml(ch1) + makeCardHtml(ch2);
    showView(3);
  }

  function collectMemo(){
    const d = {}; $$('textarea[data-memo]').forEach(t => d[t.dataset.memo] = t.value.trim()); return d;
  }

  function buildReview(){
    $('#rSit').textContent = CURRENT ? situationText(CURRENT) : '';
    const d = collectMemo();
    $$('.content[data-r]').forEach(el => {
      const v = d[el.dataset.r];
      el.textContent = v || '（未入力）';
      if(!v) el.classList.add('empty'); else el.classList.remove('empty');
    });
  }

  function copyReview(){
    const d = collectMemo();
    const text = `【HUG Gioco ふりかえりシート】\n\n■状況\n${CURRENT?situationText(CURRENT):''}\n\n■課題\n${d.issues||'-'}\n\n■配慮\n${d.care||'-'}\n\n■対応\n${d.now||'-'}\n\n■準備\n${d.prep||'-'}\n\n■提案\n${d.propose||'-'}`;
    navigator.clipboard.writeText(text).then(() => {
      const t = $('#toast'); t.textContent = 'コピーしました！'; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    });
  }

  window.addEventListener('DOMContentLoaded', () => {
    $('#btn-draw').addEventListener('click', drawSituation);
    $('#btn-next-step1').addEventListener('click', buildStep2);
    $('#btn-next-step2').addEventListener('click', buildStep3);
    $('#btn-next-step3').addEventListener('click', () => { buildReview(); showView(4); });
    $('#btn-back-step2').addEventListener('click', () => showView(1));
    $('#btn-back-step3').addEventListener('click', () => showView(2));
    $('#btn-back-step4').addEventListener('click', () => showView(3));
    $('#btn-copy').addEventListener('click', copyReview);
    $('#btn-print').addEventListener('click', () => window.print());
    $('#btn-restart').addEventListener('click', () => { if(confirm('新しくゲームをはじめますか？')) startTool(); });
  });
</script>
</body>
</html>
