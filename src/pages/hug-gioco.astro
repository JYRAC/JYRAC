---
// ==========================================
// 1. DATA LAYER (Astroフロントマターでデータを一元管理)
// ==========================================
import Layout from '../layouts/Layout.astro';

const CARDS = [
  { id: 1, c: 'dis', txt: '避難所に指定された学校の体育館。外は激しい雨と風。', e: '⛈️' },
  { id: 2, c: 'dis', txt: '夜間に大きな地震が発生。周辺一帯が停電している。', e: '🌑' },
  { id: 3, c: 'dis', txt: '真冬の寒波のなか地震が発生。暖房が効かない。', e: '❄️' },
  { id: 4, c: 'dis', txt: '台風による大雨で、近くの河川の水位が警戒レベルに。', e: '🌊' },
  { id: 5, c: 'time', txt: '発災から「3時間後」。最初の避難者が次々と押し寄せる。', e: '⏳' },
  { id: 6, c: 'time', txt: '発災から「24時間後（1日目）」。仮設トイレが届く。', e: '🌅' },
  { id: 7, c: 'time', txt: '発災から「3日後（72時間）」。救援物資の第一陣が到着。', e: '📅' },
  { id: 8, c: 'fac', txt: '体育館のほか、教室3室と多目的ホールが使用可能。', e: '🏫' },
  { id: 9, c: 'fac', txt: '学校の受水槽が生きており、水は出るが流せない。', e: '🚰' },
  { id: 10, c: 'fac', txt: '備蓄倉庫からアルファ米300食と毛布50枚を発見。', e: '📦' },
  { id: 11, c: 'peo', txt: '乳幼児を連れた母親。授乳スペースを求めている。', e: '👶' },
  { id: 12, c: 'peo', txt: '車椅子の高齢者と、そのお世話をする家族。', e: '👨‍🦽' },
  { id: 13, c: 'peo', txt: '日本語が苦手な外国人の家族（大人2人、子ども1人）。', e: '🗣️' },
  { id: 14, c: 'peo', txt: 'ペット（大型犬）を連れて避難してきた飼い主。', e: '🐕' },
  { id: 15, c: 'peo', txt: '修学旅行中の高校生グループ30名が避難を求めてきた。', e: '🎒' }
];

const DISCUSSIONS = {
  t: ['マンホールトイレや仮設トイレをどこに設置するか？', '誰を優先して使ってもらうルールにするか？', 'トイレの清鎖やゴミ出しの担当をどう決めるか？'],
  k: ['炊き出しや物資の配布場所をどこに設けるか？', 'アレルギーや宗教上の配慮が必要な人への対応は？', '貴重な水や燃料をどう管理・節約するか？'],
  b: ['通路を確保しつつ、プライベート空間をどう作るか？', '高齢者や要配慮者のベッド位置をどこにするか？', '体育館の床の冷たさや硬さを防ぐ工夫は？']
};

const CH_CARDS = [
  { id: 'ch1', c: 'con', txt: '避難所内の連絡・情報共有をどう行うか？', e: '📢' },
  { id: 'ch2', c: 'con', txt: '外部（役場や救急）との通信手段の確保は？', e: '📱' },
  { id: 'ch3', c: 'sup', txt: '届いた物資の仕分け・管理の担当者をどうするか？', e: '🤝' },
  { id: 'ch4', c: 'sup', txt: '避難者同士のトラブル（騒音・ペット等）の対応は？', e: '⚡' }
];
---

<Layout title="HUG Gioco — TKB型避難所運営ディスカッションゲーム" currentTab="gioco">
  
  <div class="gioco-local-wrapper" id="jyrac-gioco-root">
    
    <header class="game-inner-header">
      <div class="titles-area">
        <b>HUG Gioco</b>
        <span>TKB型避難所運営ディスカッションゲーム</span>
      </div>
      <div class="nav-spacer"></div>
      <a href="/gioco" class="btn-back-to-site">JYRACサイトに戻る ➔</a>
      <div class="step-dots">
        <i id="dot-0" class="on"></i>
        <i id="dot-1"></i>
        <i id="dot-2"></i>
        <i id="dot-3"></i>
        <i id="dot-4"></i>
        <i id="dot-5"></i>
      </div>
    </header>

    <div class="game-views-container">
      <div id="view-0" class="view active">
        <div class="hero">
          <div class="logo-main">
            <div class="logo-h">H</div>
            <div class="logo-u">U</div>
            <div class="logo-g2">G</div>
            <div class="logo-text-gioco">Gioco</div>
          </div>
          <span class="sub">TKB型避難所運営ディスカッションゲーム</span>
        </div>

        <p class="desc">
          カードを引いて、避難所の<span class="highlight-text">「困った」</span>をみんなで考えよう。
        </p>

        <div class="setup-box">
          <h3>🎮 ゲームをはじめる準備</h3>
          
          <div class="setup-group">
            <label>① プレイ人数を選んでください</label>
            <div class="radio-tile-group">
              <label class="radio-tile">
                <input type="radio" name="play-mode" value="1人（個人ワーク）" checked />
                <span>👤 1人</span>
              </label>
              <label class="radio-tile">
                <input type="radio" name="play-mode" value="2〜4人グループ" />
                <span>👥 2〜4人</span>
              </label>
              <label class="radio-tile">
                <input type="radio" name="play-mode" value="5人以上のグループ" />
                <span>🏫 5人以上</span>
              </label>
            </div>
          </div>

          <div class="setup-group">
            <label>② 難易度を選んでください</label>
            <div class="radio-tile-group">
              <label class="radio-tile">
                <input type="radio" name="difficulty" value="easy" />
                <span class="diff-text easy">🔰 初級 (穏やか)</span>
              </label>
              <label class="radio-tile">
                <input type="radio" name="difficulty" value="normal" checked />
                <span class="diff-text normal">⚖️ 中級 (標準)</span>
              </label>
              <label class="radio-tile">
                <input type="radio" name="difficulty" value="hard" />
                <span class="diff-text hard">🚨 上級 (修羅場)</span>
              </label>
            </div>
          </div>

          <div style="text-align: center; margin-top: 30px;">
            <button id="btn-start-game" class="game-btn big sun" type="button">🚀 ゲームを開始する</button>
          </div>
        </div>
      </div>

      <div id="view-1" class="view">
        <div class="screen-head">
          <h2>STEP 1: 避難所の状況を生成する</h2>
        </div>
        <p class="desc">
          「カードを引く」ボタンを押すと、あなたが割り当てられた避難所の環境がランダムに決定します。
        </p>

        <div class="tkb-badge-row">
          <span class="tkb-badge t">🚾 T: Toilet (トイレ対策)</span>
          <span class="tkb-badge k">🍳 K: Kitchen (食事・炊き出し)</span>
          <span class="tkb-badge b">🛏️ B: Bed (快適な睡眠・居住)</span>
        </div>

        <div style="text-align: center; margin: 28px 0 20px;">
          <button id="btn-draw" class="game-btn big" type="button">🎲 カードを引いて状況を作る</button>
        </div>

        <div id="sit-cards" class="cards"></div>

        <div style="text-align: center; margin-top: 40px;">
          <button id="btn-next-step1" class="game-btn green" type="button" disabled>次へ進む（課題検討） ➔</button>
        </div>
      </div>

      <div id="view-2" class="view">
        <div class="screen-head">
          <h2>STEP 2: TKBの課題に向き合う</h2>
          <span class="tag">グループワーク</span>
        </div>

        <div class="situation">
          <div class="lbl">現在のシチュエーション設定</div>
          <p id="step2-sit-text"></p>
        </div>

        <div class="note-line">
          💡 下記の<b>T・K・Bそれぞれの問い</b>について、「何が問題になるか」「どう対応するか」を話し合ってみましょう。
        </div>

        <div id="q-cards-box" class="q-groups"></div>

        <div class="section-label">
          <span class="pill">記録メモ</span> ワーク中の気づきや意見をメモしよう
        </div>

        <div class="memo-grid">
          <div class="memo m1">
            <label>① 今回の状況で「想定される課題」は？</label>
            <textarea data-memo="issues" placeholder="例：停電しているので夜間のトイレが非常に危険、物資の毛布50枚に対して避難者が多すぎる、など"></textarea>
          </div>
          <div class="memo m2">
            <label>② 「特に配慮が必要な人」は誰？</label>
            <textarea data-memo="care" placeholder="例：日本語が不慣れな外国人家族への案内掲示、乳幼児の泣き声や授乳のための個室教室の割り当て、など"></textarea>
          </div>
        </div>

        <div class="final-actions">
          <button id="btn-back-step2" class="game-btn ghost small" type="button">🔀 状況を引き直す</button>
          <button id="btn-next-step2" class="game-btn green" type="button">次へ進む（アクシデント発生確認） ➔</button>
        </div>
      </div>

      <div id="view-3" class="view">
        <div class="screen-head">
          <h2>STEP 3: 突然のアクシデント・運営課題</h2>
          <span id="incident-tag" class="tag" style="background:#fde3e5; color:var(--red);">トラブル対応</span>
        </div>

        <div id="incident-alert" class="note-line" style="background:#fde3e5; border-color:var(--red); color:var(--red-deep);">
          ⚠️ <b>追加チャレンジ発生！</b> 運営ディスカッションを進める中、さらに以下のアクシデントや追加の運営問題が発生しました。どう乗り越えますか？
        </div>

        <div id="ch-cards-box" class="cards"></div>

        <div class="memo-grid">
          <div class="memo m3">
            <label>③ 混乱を防ぐために「今すぐ必要な対応」は？</label>
            <textarea data-memo="now" placeholder="例：修学旅行中の元気な高校生たちに物資搬入やゴミ集積の手伝いチームを結成してもらう、など"></textarea>
          </div>
          <div class="memo m4">
            <label>④ 普段の生活から「事前に準備すべきこと」は？</label>
            <textarea data-memo="prep" placeholder="例：学校の備蓄品見直し、防災訓練の実施など"></textarea>
          </div>
        </div>

        <div class="final-actions">
          <button id="btn-back-step3" class="game-btn ghost small" type="button">⬅ 戻る</button>
          <button id="btn-next-step3" class="game-btn green" type="button">シートをまとめて完成！ ➔</button>
        </div>
      </div>

      <div id="view-4" class="view">
        <div class="screen-head"><h2>HUG Gioco ワーク記録シート</h2></div>
        <div class="review-box">
          <div class="r-item"><h5>設定シチュエーション</h5><div id="rSit" class="content"></div></div>
          <div class="r-item"><h5>Q1. 今回の状況で「想定される課題」</h5><div class="content" data-r="issues"></div></div>
          <div class="r-item"><h5>Q2. 「特に配慮が必要な人」への気づき</h5><div class="content" data-r="care"></div></div>
          <div class="r-item"><h5>Q3. トラブルを防ぐために「今すぐ必要な対応」</h5><div class="content" data-r="now"></div></div>
          <div class="r-item"><h5>Q4. 防災のために「事前に準備・備蓄すべきこと」</h5><div class="content" data-r="prep"></div></div>
          
          <div class="r-item">
            <h5>Q5. 感想・振り返り、または地域へのアイデア</h5>
            <div class="memo m5" style="border:none; padding:0; box-shadow:none;">
              <textarea data-memo="propose" placeholder="例：プレイしてみた感想や、地域の防災訓練に活かせるアイデアなど" style="min-height:100px; margin-top:8px;"></textarea>
            </div>
          </div>
        </div>
        
        <div class="final-actions">
          <button id="btn-back-step4" class="game-btn ghost small" type="button">⬅ 修正する</button>
          <button id="btn-copy" class="game-btn sun" type="button">📋 テキストコピー</button>
          <button id="btn-print" class="game-btn sky" type="button">🖨️ A4用紙に印刷</button>
          <button id="btn-submit-sheet" class="game-btn green" type="button">☁️ 管理シートに記録して終了</button>
          <button id="btn-restart" class="game-btn red" type="button">🔄 最初からやり直す</button>
        </div>
        <div class="footer-note"><b>HUG Gioco (ジョッコ)</b> — TKB型避難所運営ディスカッションゲーム<br>協力：日本若者防災復興協会（JYRAC）</div>
      </div>

      <div id="view-5" class="view">
        <div class="success-screen">
          <div class="success-icon">✨</div>
          <h2>ワークシート送信完了！</h2>
          <p class="success-msg">データは広報局の管理スプレッドシートに正常に記録されました。<br>貴重なご意見・ディスカッションの記録をありがとうございます！</p>
          
          <div class="submitted-summary-box">
            <h4>📥 送信内容のサマリー</h4>
            <div class="summary-item"><strong>モード / 難易度:</strong> <span id="s-meta"></span></div>
            <div class="summary-item"><strong>シチュエーション:</strong> <div id="s-sit" class="sum-content"></div></div>
            <div class="summary-item"><strong>感想・提案:</strong> <div id="s-prop" class="sum-content"></div></div>
          </div>

          <div style="text-align: center; margin-top: 35px;">
            <button id="btn-finish-restart" class="game-btn big sun" type="button">🔄 もう一度新しくゲームを遊ぶ</button>
          </div>
        </div>
        <div class="footer-note"><b>HUG Gioco (ジョッコ)</b> — TKB型避難所運営ディスカッションゲーム<br>協力：日本若者防災復興協会（JYRAC）</div>
      </div>

    </div>
  </div>

  <div id="game-scoped-toast" class="game-scoped-toast"></div>
</Layout>

{/* ==========================================
// 3. SCOPED STYLE LAYER
// ========================================== */}
<style>
  .gioco-local-wrapper {
    --navy: #1B3A8C; --navy-deep: #152E70; --green: #2E9E4F; --green-deep: #1f7d3c; --red: #E01E2B; --red-deep: #b8161f;
    --white: #FFFFFF; --sky: #4AA9E0; --sky-soft: #DDEEFA; --sun: #FFD23F; --sun-soft: #FFF3C9; --cream: #FDFBF5; --cream-2: #F5F0E4;
    --ink: #233047; --ink-soft: #5b6779; --line: #E7E0D0; --shadow: 0 10px 24px rgba(27, 58, 140, 0.12); --shadow-lg: 0 18px 44px rgba(27, 58, 140, 0.18);
    --radius: 22px; --radius-sm: 14px;
    --primary: #009aa6;

    background: var(--cream);
    color: var(--ink);
    padding: 30px;
    border-radius: var(--radius);
    background-image: 
      radial-gradient(circle at 12% 8%, rgba(74,169,224,0.10) 0 22px, transparent 23px),
      radial-gradient(circle at 88% 14%, rgba(46,158,79,0.08) 0 26px, transparent 27px),
      radial-gradient(circle at 78% 82%, rgba(224,30,43,0.06) 0 24px, transparent 25px),
      radial-gradient(circle at 20% 90%, rgba(255,210,63,0.14) 0 30px, transparent 31px);
  }

  .game-views-container { padding: 10px 0; }

  .game-inner-header {
    border-bottom: 3px solid var(--navy);
    padding: 10px 0 15px; display: flex; align-items: center; gap: 12px;
    margin-bottom: 25px;
  }
  .game-inner-header .titles-area { display: flex; flex-direction: column; line-height: 1.15; }
  .game-inner-header .titles-area b { font-family: 'Baloo 2', sans-serif; font-weight: 800; font-size: 1.18rem; color: var(--navy); letter-spacing: 0.5px; }
  .game-inner-header .titles-area span { font-size: 0.72rem; color: var(--ink-soft); font-weight: 700; }
  .game-inner-header .nav-spacer { flex: 1; }
  .step-dots { display: flex; gap: 7px; align-items: center; }
  .step-dots i { width: 11px; height: 11px; border-radius: 50%; background: var(--line); display: block; transition: 0.25s; }
  .step-dots i.on { background: var(--navy); transform: scale(1.25); }
  .step-dots i.done { background: var(--green); }
  
  .btn-back-to-site { font-weight:700; font-size:.85rem; color: var(--navy); text-decoration:none; background:#fff; border:2px solid var(--navy); padding:6px 16px; border-radius:999px; transition:.2s; display:inline-flex; align-items:center; gap:6px; margin-right: 15px; }
  .btn-back-to-site:hover { background:var(--navy); color:#fff; }

  /* 初期設定画面タイルUI */
  .setup-box { background: #fff; padding: 24px; border-radius: var(--radius-sm); box-shadow: var(--shadow); max-width: 600px; margin: 0 auto; text-align: left; }
  .setup-box h3 { color: var(--navy); font-weight: 800; margin-top: 0; margin-bottom: 20px; border-bottom: 2px dashed var(--line); padding-bottom: 10px; }
  .setup-group { margin-bottom: 20px; }
  .setup-group label { display: block; font-weight: 800; margin-bottom: 8px; color: var(--ink); font-size: 0.95rem; }
  
  .radio-tile-group { display: flex; gap: 10px; }
  .radio-tile { flex: 1; cursor: pointer; display: block; text-align: center; }
  .radio-tile input { display: none; }
  .radio-tile span { display: block; padding: 12px; border: 2px solid var(--line); border-radius: 12px; font-weight: 700; background: #fafafa; transition: 0.2s; font-size: 0.9rem; }
  .radio-tile input:checked + span { border-color: var(--navy); background: var(--sky-soft); color: var(--navy); }
  .radio-tile input:checked + .diff-text.easy { border-color: var(--green); background: #eafaf1; color: var(--green-deep); }
  .radio-tile input:checked + .diff-text.normal { border-color: var(--sun); background: var(--sun-soft); color: #8a6d00; }
  .radio-tile input:checked + .diff-text.hard { border-color: var(--red); background: #fde8e8; color: var(--red-deep); }

  /* 💡 新設：送信完了画面スタイル */
  .success-screen { background: #white; padding: 40px 20px; text-align: center; max-width: 650px; margin: 0 auto; }
  .success-icon { font-size: 4rem; margin-bottom: 15px; animation: float 2s ease-in-out infinite; }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .success-screen h2 { color: var(--green); font-weight: 900; font-size: 1.8rem; margin-bottom: 12px; }
  .success-msg { color: var(--ink-soft); font-weight: 500; font-size: 1.05rem; line-height: 1.6; margin-bottom: 30px; }
  .submitted-summary-box { background: var(--white); border: 2px solid var(--line); border-radius: var(--radius-sm); padding: 20px; box-shadow: var(--shadow); text-align: left; }
  .submitted-summary-box h4 { color: var(--navy); font-weight: 800; margin: 0 0 15px 0; border-bottom: 2px dashed var(--line); padding-bottom: 8px; }
  .summary-item { margin-bottom: 12px; font-size: 0.95rem; }
  .summary-item:last-child { margin-bottom: 0; }
  .summary-item strong { color: var(--navy); display: block; margin-bottom: 4px; }
  .sum-content { background: #fafafa; border-radius: 8px; padding: 10px; font-weight: 500; border: 1px solid var(--line); white-space: pre-wrap; font-size: 0.9rem; }

  .game-btn {
    font-family: 'Baloo 2', 'Zen Maru Gothic', sans-serif; font-weight: 800; border: none; cursor: pointer; border-radius: 999px;
    padding: 14px 26px; font-size: 1.05rem; color: #fff; background: var(--navy);
    box-shadow: 0 6px 0 var(--navy-deep), 0 12px 22px rgba(27, 58, 140, 0.28);
    transition: transform 0.08s ease, box-shadow 0.08s ease; display: inline-flex; align-items: center; gap: 10px; justify-content: center;
  }
  .game-btn:active { transform: translateY(4px); box-shadow: 0 2px 0 var(--navy-deep), 0 6px 12px rgba(27, 58, 140, 0.24); }
  .game-btn.green { background: var(--green); box-shadow: 0 6px 0 var(--green-deep), 0 12px 22px rgba(46, 158, 79, 0.28); }
  .game-btn.red { background: var(--red); box-shadow: 0 6px 0 var(--red-deep), 0 12px 22px rgba(224, 30, 43, 0.26); }
  .game-btn.sky { background: var(--sky); box-shadow: 0 6px 0 #2b87bd, 0 12px 22px rgba(74, 169, 224, 0.28); }
  .game-btn.sun { background: var(--sun); color: var(--navy); box-shadow: 0 6px 0 #e0b325, 0 12px 22px rgba(255, 210, 63, 0.4); }
  .game-btn.ghost { background: #fff; color: var(--navy); border: 2.5px solid var(--navy); box-shadow: 0 6px 0 rgba(27, 58, 140, 0.16); }
  .game-btn.small { padding: 11px 20px; font-size: 0.95rem; }
  .game-btn.big { padding: 18px 36px; font-size: 1.25rem; }
  .game-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  #jyrac-gioco-root .view { display: none !important; }
  #jyrac-gioco-root .view.active { display: block !important; animation: pop 0.4s ease forwards; }
  @keyframes pop { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

  .hero { text-align: center; padding: 12px 0 6px; }
  .logo-main { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 15px; font-family: 'Baloo 2', sans-serif; filter: drop-shadow(0 8px 16px rgba(27,58,140,0.12)); }
  .logo-h, .logo-u, .logo-g2 { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; font-size: 32px; font-weight: 800; border-radius: 14px; position: relative; box-shadow: inset 0 -4px 0 rgba(0,0,0,0.15), 0 4px 10px rgba(0,0,0,0.08); text-shadow: 0 2px 4px rgba(0,0,0,0.15); line-height: 1; color:#fff; }
  .logo-h::before, .logo-u::before, .logo-g2::before { content: ''; position: absolute; top: -12px; left: 0; right: 0; margin: auto; width: 0; height: 0; border-left: 26px solid transparent; border-right: 26px solid transparent; }
