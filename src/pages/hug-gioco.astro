---
// src/pages/gioco.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="HUG Gioco (教材) | 日本若者防災復興協会" currentTab="gioco">
    <div class="content-panel">
        <h2>HUG Gioco — 避難所運営ディスカッションゲーム</h2>
        
        <div class="info-card-box">
            <p>
                <strong>【JYRAC独自開発・デジタルふりかえりシートツール】</strong><br><br>
                「HUG Gioco（グロッコ）」は、TKB（トイレ・キッチン・ベッド）型避難所運営をテーマにした、子どもから大人まで直感的に学べる防災シミュレーションディスカッションゲームです。<br><br>
                従来の避難所運営ゲームの枠を超え、ゲームを通じて見つかった地域のリアルな課題や、配慮が必要な避難者への対応策をその場でスマホ・タブレットから入力・集約し、学校や自治体へ提出できる「次世代のデジタルふりかえりシート」をJYRACが完全独自開発しました。
            </p>
            
            <div style="text-align: center; margin: 30px 0;">
                <a href="/hug-gioco" class="btn-gioco-launch-large" target="_blank" rel="noopener">
                    ふりかえりシートツールを起動する ➔
                </a>
                <p style="font-size: 12px; color: #7f8c8d; margin-top: 12px;">※ゲーム画面が新しいウインドウ（フル画面）で開きます。</p>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* 💡 ツール起動ボタンを単体でも完璧なデザインで表示するための専用スタイル */
    .btn-gioco-launch-large {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        color: #ffffff;
        padding: 20px 38px;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 15px;
        transition: all 0.3s ease;
        background: linear-gradient(135deg, #1B3A8C 0%, #152E70 100%);
        box-shadow: 0 6px 20px rgba(27, 58, 140, 0.2);
        border: 1px solid rgba(74, 169, 224, 0.3);
        cursor: pointer;
    }
    .btn-gioco-launch-large:hover {
        transform: translate3d(0, -4px, 0);
        box-shadow: 0 12px 30px rgba(27, 58, 140, 0.4);
        border-color: #4AA9E0;
    }
</style>
