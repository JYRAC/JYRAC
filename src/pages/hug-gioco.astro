  .tkb-badge-row { display: flex; justify-content: center; gap: 14px; margin-bottom: 24px; flex-wrap: wrap; }
  .tkb-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 18px; border-radius: 999px; font-size: 0.95rem; font-weight: 800; color: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
  .tkb-badge.t { background: var(--green); } .tkb-badge.k { background: var(--red); } .tkb-badge.b { background: var(--navy); }

  .cards { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); }
  .gcard {
    position: relative; background: #fff; border-radius: var(--radius-sm); padding: 20px 16px;
    box-shadow: var(--shadow); border-left: 7px solid var(--navy); overflow: hidden; text-align: left;
  }
  .gcard .cat { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .gcard .txt { font-weight: 700; font-size: 1.02rem; line-height: 1.45; color: var(--ink); }
  .gcard .emoji { position: absolute; right: 8px; top: 8px; font-size: 1.4rem; opacity: 0.9; }
  
  .c-dis { border-left-color: var(--red); } .c-dis .cat { color: var(--red-deep); }
  .c-time { border-left-color: var(--sky); } .c-time .cat { color: #2b7fb0; }
  .c-fac { border-left-color: var(--navy); } .c-fac .cat { color: var(--navy-deep); }
  .c-peo { border-left-color: var(--sun); background: linear-gradient(180deg, #fffdf4 0%, #fff 100%); } .c-peo .cat { color: #b58900; }
  .c-con { border-left-color: #7a5cc0; background: linear-gradient(180deg, #f7f4ff 0%, #fff 100%); } .c-con .cat { color: #5c3fa0; }
  .c-sup { border-left-color: var(--green); background: linear-gradient(180deg, #f2fbf5 0%, #fff 100%); } .c-sup .cat { color: var(--green-deep); }

  .situation { background: linear-gradient(135deg, var(--navy), #2a52b0); color: #fff; border-radius: var(--radius-sm); padding: 18px 20px; margin-bottom: 20px; box-shadow: var(--shadow); text-align: left; }
  .situation .lbl { font-weight: 800; font-size: 0.85rem; opacity: 0.85; }
  .situation p { font-size: 1.1rem; font-weight: 700; margin: 6px 0 0; line-height: 1.7; }

  .q-groups { display: grid; gap: 14px; grid-template-columns: 1fr; margin-bottom: 20px; }
  @media(min-width: 760px) { .q-groups { grid-template-columns: 1fr 1fr 1fr; } }
  .q-card { background: #fff; border-radius: var(--radius-sm); padding: 16px; box-shadow: var(--shadow); border-top: 6px solid var(--sky); }
  .q-card.a { border-top-color: var(--red); } .q-card.b { border-top-color: var(--green); } .q-card.c { border-top-color: var(--sun); }
  .q-card h4 { color: var(--navy); margin: 0 0 10px 0; font-size: 1rem; font-weight: 800; text-align: left; }
  .q-card ul { margin: 0; padding: 0; list-style: none; }
  .q-card li { position: relative; padding: 5px 0 5px 22px; font-size: 0.9rem; border-bottom: 1px dashed var(--line); color: var(--ink); font-weight: 700; text-align: left; }
  .q-card li::before { content: "？"; position: absolute; left: 0; top: 4px; width: 16px; height: 16px; background: var(--sky-soft); color: var(--navy); border-radius: 50%; font-size: 0.65rem; font-weight: 800; display: inline-flex; align-items: center; justify-content: center; }
  .q-card.a li::before { background: #fde8e8; color: var(--red); } .q-card.b li::before { background: #eafaf1; color: var(--green); } .q-card.c li::before { background: var(--sun-soft); color: #a67c00; }

  .section-label { display: flex; align-items: center; gap: 6px; font-weight: 800; color: var(--navy); font-size: 1rem; margin: 20px 0 10px; }
  .section-label .pill { background: var(--navy); color: #fff; border-radius: 6px; font-size: 0.7rem; padding: 2px 8px; }

  .memo-grid { display: grid; gap: 16px; grid-template-columns: 1fr; margin-bottom: 25px; }
  @media(min-width: 720px) { .memo-grid { grid-template-columns: 1fr 1fr; } }
  .memo { background: #fff; border-radius: var(--radius-sm); padding: 16px; box-shadow: var(--shadow); border-left: 6px solid var(--navy); text-align: left; }
  .memo.m1 { border-left-color: var(--red); } .memo.m2 { border-left-color: var(--sun); }
  .memo.m3 { border-left-color: var(--sky); } .memo.m4 { border-left-color: var(--green); }
  .memo.m5 { border-left-color: #7a5cc0; }
  .memo label { font-weight: 800; color: var(--navy); display: block; margin-bottom: 8px; font-size: 0.95rem; }
  .memo textarea { width: 100%; border: 2px solid var(--line); border-radius: 12px; padding: 10px; font-family: inherit; font-size: 0.95rem; resize: vertical; min-height: 85px; background: #fafafa; color: var(--ink); font-weight: 500; }
  .memo textarea:focus { outline: none; border-color: var(--primary); background: #fff; }

  .review-box { background: #fff; border-radius: var(--radius-sm); padding: 20px; box-shadow: var(--shadow); border: 2px solid var(--navy); text-align: left; }
  .r-item { border-bottom: 2px dashed var(--line); padding: 12px 0; }
  .r-item:first-child { padding-top: 0; } .r-item:last-child { border-bottom: none; padding-bottom: 0; }
  .r-item h5 { color: var(--navy); margin: 0 0 6px 0; font-size: 0.98rem; font-weight: 800; }
  .r-item .content { white-space: pre-wrap; color: var(--ink); font-size: 0.95rem; font-weight: 500; }
  .r-item .empty { color: #b7bdc7; font-style: italic; }

  .final-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; margin-top: 25px; }
  .footer-note { text-align: center; color: var(--ink-soft); font-size: 0.8rem; margin-top: 40px; padding: 15px; background: rgba(255,255,255,0.5); border-radius: 12px; border: 1px dashed var(--line); }

  .game-scoped-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(30px); background: var(--navy); color: #fff; padding: 13px 26px; border-radius: 999px; font-weight: 800; box-shadow: var(--shadow-lg); opacity: 0; pointer-events: none; transition: 0.3s; z-index: 200; }
  .game-scoped-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media print {
    .game-inner-header, .final-actions, .step-dots, .btn, .footer-note, .note-line { display: none !important; }
    .gioco-local-wrapper { background: #fff !important; background-image: none !important; padding: 0; }
    #jyrac-gioco-root .view { display: none !important; }
    #jyrac-gioco-root .view#view-4 { display: block !important; }
    .review-box { box-shadow: none; border: 2px solid #000; }
    .memo.m5 textarea { border: none; background: transparent; padding: 0; }
  }
</style>

{/* ==========================================
// 4. SCRIPT LAYER (進行・ゲームロジック・API送信：完全防御版)
// ========================================== */}
<script is:inline define:vars={{ CARDS, DISCUSSIONS, CH_CARDS }}>
  function setupGiocoEngine() {
    const root = document.getElementById('jyrac-gioco-root');
    if (!root) return;

    let DECK = [...CARDS];
    let CURRENT = null;
    let GAME_SETTINGS = { players: "1人", difficulty: "normal" };
    let HAS_INCIDENT = true;

    // 💡 常に現在のDOM構造からリアルタイム検索するヘルパー
    const $ = sel => root.querySelector(sel);
    const $$ = sel => root.querySelectorAll(sel);

    function showView(id) {
      $$('.view').forEach(v => v.classList.remove('active'));
      const target = $(`#view-${id}`);
      if(target) target.classList.add('active');
      
      root.querySelectorAll('.step-dots i').forEach((dot, idx) => {
        dot.className = '';
        if(idx === id) dot.className = 'on';
        else if(idx < id) dot.className = 'done';
      });
      window.scrollTo(0,0);
    }

    function makeCardHtml(c){
      const catMaps = {dis:'災害・状況',time:'経過時間',fac:'施設・物資',peo:'避難者',con:'運営・情報',sup:'支援・対話'};
      return `<div class="gcard c-${c.c}"><span class="emoji">${c.e}</span><div class="cat">${catMaps[c.c] || c.c}</div><div class="txt">${c.txt}</div></div>`;
    }

    function sample(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
    function shuffle(arr) { return arr.sort(() => Math.random() - 0.5); }

    function startTool(){
      DECK = [...CARDS]; CURRENT = null;
      root.querySelectorAll('textarea[data-memo]').forEach(t => t.value = '');
      
      const rSit = $('#rSit');
      const sitCards = $('#sit-cards');
      const btnNext1 = $('#btn-next-step1');
      
      if(rSit) rSit.textContent = '';
      if(sitCards) sitCards.innerHTML = '';
      if(btnNext1) btnNext1.disabled = true;
      showView(0);
    }

    function handleStartGame() {
      const modeInput = $('input[name="play-mode"]:checked');
      const diffInput = $('input[name="difficulty"]:checked');
      if(modeInput) GAME_SETTINGS.players = modeInput.value;
      if(diffInput) GAME_SETTINGS.difficulty = diffInput.value;
      showView(1);
    }

    function drawSituation(e){
      if(e) e.preventDefault();
      const dis = DECK.filter(c => c.c === 'dis'), 
            time = DECK.filter(c => c.c === 'time'), 
            fac = DECK.filter(c => c.c === 'fac'), 
            peo = shuffle([...DECK.filter(c => c.c === 'peo')]);
      
      const c1 = sample(dis), c2 = sample(time), c3 = sample(fac);
      
      let pCards = [];
      if (GAME_SETTINGS.difficulty === 'easy') {
        pCards = [peo[0]];
      } else if (GAME_SETTINGS.difficulty === 'normal') {
        pCards = [peo[0], peo[1]];
      } else {
        pCards = [peo[0], peo[1], peo[2]];
      }

      CURRENT = { dis:c1, time:c2, fac:c3, people: pCards };

      let html = makeCardHtml(c1) + makeCardHtml(c2) + makeCardHtml(c3);
      pCards.forEach(p => html += makeCardHtml(p));
      
      const sitCards = $('#sit-cards');
      const btnNext1 = $('#btn-next-step1');
      if(sitCards) sitCards.innerHTML = html;
      if(btnNext1) btnNext1.disabled = false;
    }

    function situationText(cur){
      if(!cur) return '';
      const pText = cur.people.map(p => `【${p.txt}】`).join('や');
      return `【${cur.dis.txt}】のなか、発災から【${cur.time.txt}】が経過。避難所環境は【${cur.fac.txt}】という条件です。そこへ${pText}が避難しています。`;
    }

    function buildStep2(e){
      if(e) e.preventDefault();
      if(!CURRENT) return;
      
      const pText = CURRENT.people.map(p => p.txt).join(' ／ ');
      const step2SitText = $('#step2-sit-text');
      const qCardsBox = $('#q-cards-box');
      
      if(step2SitText) {
        step2SitText.innerHTML = `外の状況：<b>${CURRENT.dis.txt}</b><br>時間の経過：<b>${CURRENT.time.txt}</b><br>使えるもの：<b>${CURRENT.fac.txt}</b><br>避難者の様子：<b>${pText}</b>`;
      }
      
      if(qCardsBox) {
        qCardsBox.innerHTML = `
          <div class="q-card a"><h4>🚾 T トイレの課題</h4><ul><li>${sample(DISCUSSIONS.t)}</li></ul></div>
          <div class="q-card b"><h4>🍳 K キッチンの課題</h4><ul><li>${sample(DISCUSSIONS.k)}</li></ul></div>
          <div class="q-card c"><h4>🛏️ B ベッドの課題</h4><ul><li>${sample(DISCUSSIONS.b)}</li></ul></div>`;
      }
      showView(2);
    }

    function buildStep3(e){
      if(e) e.preventDefault();
      
      const rate = GAME_SETTINGS.difficulty === 'easy' ? 0.4 : GAME_SETTINGS.difficulty === 'normal' ? 0.75 : 1.0;
      HAS_INCIDENT = Math.random() < rate;

      const incTag = $('#incident-tag');
      const incAlert = $('#incident-alert');
      const chCardsBox = $('#ch-cards-box');

      if (HAS_INCIDENT) {
        if(incTag) {
          incTag.style.background = '#fde3e5';
          incTag.style.color = 'var(--red)';
          incTag.textContent = 'トラブル対応';
        }
        if(incAlert) {
          incAlert.style.display = 'block';
          incAlert.style.background = '#fde3e5';
          incAlert.style.borderColor = 'var(--red)';
          incAlert.style.color = 'var(--red-deep)';
          incAlert.innerHTML = '⚠️ <b>追加チャレンジ発生！</b> 運営ディスカッションを進める中、さらに以下のアクシデントや追加の運営問題が発生しました。どう乗り越えますか？';
        }
        
        let pool = shuffle([...CH_CARDS]);
        let count = GAME_SETTINGS.difficulty === 'hard' ? 2 : 1;
        let html = '';
        for(let i=0; i<count; i++) { html += makeCardHtml(pool[i]); }
        if(chCardsBox) chCardsBox.innerHTML = html;
      } else {
        if(incTag) {
          incTag.style.background = '#eafaf1';
          incTag.style.color = 'var(--green)';
          incTag.textContent = '比較的平穏';
        }
        if(incAlert) {
          incAlert.style.display = 'block';
          incAlert.style.background = '#eafaf1';
          incAlert.style.borderColor = 'var(--green)';
          incAlert.style.color = 'var(--green-deep)';
          incAlert.innerHTML = '🍀 <b>追加アクシデントは発生しませんでした。</b> 現在の体制維持と、次の時間経過に向けた運営の効率化を話し合ってください。';
        }
        if(chCardsBox) chCardsBox.innerHTML = '<div style="padding:20px; font-weight:700; color:var(--ink-soft);">追加のトラブルはありません。</div>';
      }
      showView(3);
    }

    function collectMemo(){
      const d = {}; 
      root.querySelectorAll('textarea[data-memo]').forEach(t => d[t.dataset.memo] = t.value.trim()); 
      return d;
    }

    function buildStep2(e){
      if(e) e.preventDefault();
      if(!CURRENT) return;
      
      const pText = CURRENT.people.map(p => p.txt).join(' ／ ');
      const step2SitText = $('#step2-sit-text');
      const qCardsBox = $('#q-cards-box');
      
      if(step2SitText) {
        step2SitText.innerHTML = `外の状況：<b>${CURRENT.dis.txt}</b><br>時間の経過：<b>${CURRENT.time.txt}</b><br>使えるもの：<b>${CURRENT.fac.txt}</b><br>避難者の様子：<b>${pText}</b>`;
      }
      
      if(qCardsBox) {
        qCardsBox.innerHTML = `
          <div class="q-card a"><h4>🚾 T トイレの課題</h4><ul><li>${sample(DISCUSSIONS.t)}</li></ul></div>
          <div class="q-card b"><h4>🍳 K キッチンの課題</h4><ul><li>${sample(DISCUSSIONS.k)}</li></ul></div>
          <div class="q-card c"><h4>🛏️ B ベッドの課題</h4><ul><li>${sample(DISCUSSIONS.b)}</li></ul></div>`;
      }
      showView(2);
    }

    function buildReview(){
      const rSit = $('#rSit');
      if(rSit) rSit.textContent = CURRENT ? situationText(CURRENT) : '';
      
      const d = collectMemo();
      root.querySelectorAll('.content[data-r]').forEach(el => {
        const v = d[el.dataset.r];
        el.textContent = v || '（未入力）';
        if(!v) el.classList.add('empty'); else el.classList.remove('empty');
      });
    }

    function copyReview(e) {
      if(e) e.preventDefault();
      const d = collectMemo();
      const sit = CURRENT ? situationText(CURRENT) : '（シチュエーション未作成）';
      const text = `【HUG Gioco ワーク記録シート】\nプレイ人数:${GAME_SETTINGS.players} / 難易度:${GAME_SETTINGS.difficulty}\n\n■状況\n${sit}\n\n■課題\n${d.issues||'-'}\n\n■配慮\n${d.care||'-'}\n\n■対応\n${d.now||'-'}\n\n■準備\n${d.prep||'-'}\n\n■感想・提案\n${d.propose||'-'}`;
      navigator.clipboard.writeText(text).then(() => {
        showToast('📋 クリップボードにコピーしました！');
      });
    }

    // 💡 画面を切り替えて送信結果を表示するサマリー構築関数
    function buildSuccessScreen() {
      const d = collectMemo();
      const sMeta = $('#s-meta');
      const sSit = $('#s-sit');
      const sProp = $('#s-prop');

      if(sMeta) sMeta.textContent = `${GAME_SETTINGS.players} ／ 難易度: ${GAME_SETTINGS.difficulty}`;
      if(sSit) sSit.textContent = CURRENT ? situationText(CURRENT) : '';
      if(sProp) sProp.textContent = d.propose || '（未入力）';
    }

    function submitToSpreadsheet(e) {
      if(e) e.preventDefault();
      const d = collectMemo();
      const sit = CURRENT ? situationText(CURRENT) : '';
      
      const payload = {
        timestamp: new Date().toISOString(),
        players: GAME_SETTINGS.players,
        difficulty: GAME_SETTINGS.difficulty,
        situation: sit,
        issues: d.issues,
        care: d.care,
        now: d.now,
        prep: d.prep,
        propose: d.propose
      };

      const WEBHOOK_URL = "https://script.google.com/macros/s/AKfycbz08QcBxBqNCqrbp6zqeT0kPDgyhRE6bepihXxqITuCA_-9mt5ByIcr65qqlDirCrZR/exec";

      showToast('☁️ データを送信中...');

      if(WEBHOOK_URL.includes("XXXXXXXXXXXXXXXXXXXXXX")) {
        setTimeout(() => {
          showToast('💡 URLが未設定のためダミー送信に成功しました！');
          buildSuccessScreen();
          showView(5);
        }, 1200);
        return;
      }

      fetch(WEBHOOK_URL, {
        method: "POST",
        mode: "no-cors",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      })
      .then(() => {
        // 💡 送信完了時にトーストを出しつつ、送信結果画面 (view-5) へシフト
        showToast('✅ 管理スプレッドシートに記録されました！');
        buildSuccessScreen();
        showView(5);
      })
      .catch(err => {
        console.error(err);
        showToast('❌ 送信に失敗しました。ネット環境を確認してください。');
      });
    }

    function showToast(msg) {
      const t = root.querySelector('#game-scoped-toast'); 
      if (!t) {
        console.log("Toast (Fallback):", msg);
        return;
      }
      t.textContent = msg; 
      t.classList.add('show');
      
      if (window.toastTimeout) clearTimeout(window.toastTimeout);
      window.toastTimeout = setTimeout(() => {
        const currentToast = root.querySelector('#game-scoped-toast');
        if (currentToast) currentToast.classList.remove('show');
      }, 2500);
    }

    // 【完全防御】イベント委譲（Event Delegation）によるルーティング
    root.onclick = function(e) {
      const target = e.target.closest('button, a');
      if (!target || !target.id) return;

      switch(target.id) {
        case 'btn-start-game': handleStartGame(); break;
        case 'btn-draw':       drawSituation(e); break;
        case 'btn-next-step1': buildStep2(e); break;
        case 'btn-next-step2': buildStep3(e); break;
        case 'btn-next-step3': e.preventDefault(); buildReview(); showView(4); break;
        
        case 'btn-back-step2': e.preventDefault(); showView(1); break;
        case 'btn-back-step3': e.preventDefault(); showView(2); break;
        case 'btn-back-step4': e.preventDefault(); showView(3); break;
        
        case 'btn-copy':           copyReview(e); break;
        case 'btn-print':          e.preventDefault(); window.print(); break;
        case 'btn-submit-sheet':   submitToSpreadsheet(e); break;
        case 'btn-restart':
        case 'btn-finish-restart': e.preventDefault(); if(confirm('新しくゲームをはじめますか？')) startTool(); break;
      }
    };

    showView(0);
  }

  document.addEventListener('DOMContentLoaded', setupGiocoEngine);
  document.addEventListener('astro:page-load', setupGiocoEngine);
  setupGiocoEngine();
</script>
