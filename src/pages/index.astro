---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// CMSがない状態でも安全に動作する初期データ
const cmsNews = null; 

const externalNews = cmsNews || [
  {
    date: "2026.06.17",
    label: "お知らせ",
    title: "東京都よりNPO法人の設立認証を受け、登記申請手続きを開始しました。",
    content: "東京都知事より特定非営利活動法人（NPO法人）の設立認証を正式に受けました。現在は東京法務局にて設立登記の申請手続きを進めております。"
  },
  {
    date: "2026.04.10",
    label: "重要",
    title: "東京都へ特定非営利活動法人（NPO法人）の設立認証申請を行いました。",
    content: "本日、所轄庁である東京都へ特定非営利活動法人の認証申請書類一式を正式に提出いたしました。"
  }
];
---

<Layout title="日本若者防災復興協会" currentTab="news">
    <div class="content-panel">
        <h2>新着情報・お知らせ一覧</h2>
        {externalNews && externalNews.length > 0 ? (
            <ul class="news-list">
                {externalNews.map((item) => (
                    <li class="news-item">
                        <div class="news-header">
                            <span class="news-date">{item.date}</span>
                            <span class="news-label">{item.label}</span>
                            <span class="news-title">{item.title}</span>
                            <span class="news-icon"></span>
                        </div>
                        <div class="news-body">
                            <div class="news-body-inner" set:html={item.content}></div>
                        </div>
                    </li>
                ))}
            </ul>
        ) : (
            <p style="color: #7f8c8d; text-align: center; padding: 40px 0;">現在、新しいお知らせはありません。</p>
        )}
    </div>
</Layout>