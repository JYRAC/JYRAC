---
import Layout from '../layouts/Layout.astro';

// CMSがない状態でも安全に動作する初期データ
const cmsNews = null; 

const externalNews = cmsNews || [
  {
    date: "2026.07.15",
    label: "重要",
    title: "【設立登記完了】特定非営利活動法人日本若者防災復興協会として正式に成立いたしました。",
    content: "本日、東京法務局における設立登記手続きが無事に完了いたしました。これにより、当団体は令和8年6月21日を成立日とし、法人格を有する「特定非営利活動法人 日本若者防災復興協会（JYRAC）」として正式にスタートいたしました。若者が主体となる防災・復興活動のさらなるアップデートに向け、より一層尽力してまいります。"
  },
  {
    date: "2026.06.17",
    label: "お知らせ",
    title: "東京都よりNPO法人の設立認証を受け、登記申請手続きを開始しました。",
    content: "東京都知事より特定非営利活動法人（NPO法人）の設立認証を正式に受けました。東京法務局にて設立登記の申請手続きを進めております。"
  },
  {
    date: "2026.04.10",
    label: "重要",
    title: "東京都へ特定非営利活動法人（NPO法人）の設立認証申請を行いました。",
    content: "所轄庁である東京都へ特定非営利活動法人の認証申請書類一式を正式に提出いたしました。"
  }
];
---

<Layout title="日本若者防災復興協会" currentTab="news">
    <div class="content-panel">
        <h2>新着情報・お知らせ一覧</h2>
        {externalNews && externalNews.length > 0 ? (
            <ul class="news-list">
                {externalNews.map((item, index) => (
                    <li class="news-item">
                        <div class="news-header">
                            <span class="news-date">{item.date}</span>
                            <span class="news-label" style={item.label === '重要' ? 'background: #e67e22;' : 'background: #009aa6;'}>{item.label}</span>
                            <span class="news-title">{item.title}</span>
                            <span class="news-icon"></span>
                        </div>
                        <div class="news-body">
                            <div class="news-body-inner" set:html={item.content}></div>
                        </div>
                    </li>
                ))}
            </ul>
        ) : (
            <p style="color: #7f8c8d; text-align: center; padding: 40px 0;">現在、新しいお知らせはありません。</p>
        )}
    </div>
</Layout>

<style>
  /* 💡 index.astro 専用のクリーンなスタイル指定 */
  .content-panel {
    padding: 10px 0;
  }
  h2 {
    color: #002b54;
    font-size: 20px;
    font-weight: 800;
    margin-top: 0;
    margin-bottom: 30px;
    border-left: 5px solid #009aa6;
    padding-left: 15px;
  }
  .news-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .news-item {
    background: #ffffff;
    border: 1px solid rgba(0, 154, 166, 0.15);
    border-radius: 14px;
    padding: 20px 24px;
    box-shadow: 0 4px 15px rgba(0, 43, 84, 0.02);
  }
  .news-header {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .news-date {
    font-size: 14px;
    color: #5b6779;
    font-weight: 700;
  }
  .news-label {
    font-size: 11px;
    font-weight: 800;
    color: #fff;
    padding: 2px 10px;
    border-radius: 6px;
  }
  .news-title {
    font-size: 15px;
    font-weight: 700;
    color: #002b54;
  }
  .news-body {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed #e7e0d0;
    color: #4f5e71;
    font-size: 14px;
    line-height: 1.8;
  }
</style>
