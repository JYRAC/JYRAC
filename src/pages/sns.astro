---
import Layout from '../layouts/Layout.astro';

// 1. DATA LAYER (SNSリンクのURLや文言を一元管理)
const jyracSns = [
  {
    type: "x",
    title: "X (旧Twitter) ➔",
    url: "https://x.com/jyrac_official",
    desc: "JYRAC法人の公式プレス、お知らせ、ニュースなどをテキストで発信しています。"
  },
  {
    type: "instagram",
    title: "Instagram ➔",
    url: "https://www.instagram.com/jyrac_official",
    desc: "活動報告やNSFとの共同投稿などを、写真やリール動画で投稿しています。"
  },
  {
    type: "note",
    title: "note (※JYRACのみ) ➔",
    url: "https://note.com/jyrac_official",
    desc: "防災・復興に対する代表や役員の想い、活動の背景にあるストーリーをコラム形式などで発信しています。"
  }
];

const nsfSns = [
  {
    type: "x",
    title: "X (旧Twitter) ➔",
    url: "https://x.com/nsf_project",
    desc: "お知らせ、ニュースなどをに発信しています。"
  },
  {
    type: "instagram",
    title: "Instagram ➔",
    url: "https://www.instagram.com/nsf_project",
    desc: "活動報告や、JYRAC、各種プロジェクトと共同投稿やイベント告知などを発信しています。"
  }
];
---

<Layout title="公式SNS一覧 | 日本若者防災復興協会" currentTab="sns">
  <div class="content-panel">
    <h2>公式SNS一覧</h2>
    <p class="lead-text">
      日本若者防災復興協会（JYRAC）、および傘下のNSF PROJECTsの公式SNSアカウント一覧です。活動のリアルタイム進捗や、若者目線での防災・減災を目指し発信しています。
    </p>
    
    <h3 class="sns-group-title">🏢 日本若者防災復興協会（JYRAC）</h3>
    <div class="sns-grid sns-grid-triple">
      {jyracSns.map((sns) => (
        <a href={sns.url} class={`sns-card sns-${sns.type}`} target="_blank" rel="noopener">
          <h4>{sns.title}</h4>
          <p>{sns.desc}</p>
        </a>
      ))}
    </div>

    <h3 class="sns-group-title" style="margin-top: 45px;">🎓 NSF PROJECTs</h3>
    <div class="sns-grid">
      {nsfSns.map((sns) => (
        <a href={sns.url} class={`sns-card sns-${sns.type}`} target="_blank" rel="noopener">
          <h4>{sns.title}</h4>
          <p>{sns.desc}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>

{/* ==========================================
// 3. SCOPED STYLE LAYER (Astro標準：他ページへのスタイル漏れを完全遮断)
// ========================================== */}
<style>
  .content-panel {
    padding: 10px 0;
  }

  h2 {
    color: #002b54;
    font-size: 24px;
    font-weight: 800;
    margin-top: 0;
    margin-bottom: 35px;
    padding-bottom: 15px;
    border-bottom: 1px solid rgba(0, 154, 166, 0.15);
    position: relative;
  }
  h2::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #009aa6 0%, #00d2e0 100%);
    border-radius: 2px;
  }

  .lead-text {
    color: #4f5e71;
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 35px;
  }

  /* グループ見出し */
  .sns-group-title {
    font-size: 16px;
    font-weight: 800;
    color: #002b54;
    margin-bottom: 16px;
    border-left: 4px solid #009aa6;
    padding-left: 10px;
    letter-spacing: 0.5px;
  }

  /* SNSカードグリッド */
  .sns-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 15px;
  }
  @media (min-width: 650px) {
    .sns-grid {
      grid-template-columns: 1fr 1fr;
    }
    .sns-grid-triple {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  /* 共通カードデザイン */
  .sns-card {
    background: #ffffff;
    border: 1px solid rgba(0, 154, 166, 0.12);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
  }
  
  .sns-card h4 {
    margin: 0 0 8px 0;
    font-size: 17px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .sns-card p {
    margin: 0;
    font-size: 13px;
    color: #7f8c8d;
    font-weight: 600;
    line-height: 1.5;
  }
  
  /* 各カードのホバー効果（他ページに影響を及ぼさない安全設計） */
  .sns-x:hover {
    border-color: #000000;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
    transform: translate3d(0, -4px, 0);
  }
  .sns-x h4 { color: #000000; }

  .sns-instagram:hover {
    border-color: #e1306c;
    box-shadow: 0 8px 25px rgba(225, 48, 108, 0.15);
    transform: translate3d(0, -4px, 0);
  }
  .sns-instagram h4 { color: #e1306c; }

  .sns-note:hover {
    border-color: #23c175;
    box-shadow: 0 8px 25px rgba(35, 193, 117, 0.12);
    transform: translate3d(0, -4px, 0);
  }
  .sns-note h4 { color: #23c175; }
</style>
