---
// src/layouts/Layout.astro
interface Props {
  title: string;
  currentTab: 'news' | 'about' | 'services' | 'governance' | 'sns' | 'contact' | 'gioco'; 
}

const { title, currentTab } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="U3N1SPErYZ6hcrPgWswh8WCyACwLkJXfE7c7QNofrBQ" />
    <meta name="description" content="日本若者防災復興協会（JYRAC）は、若者が主体となり防災・減災・災害復興に取り組むNPO法人です。" />
    <title>{title}</title>
    <link rel="icon" href="/JYRAC.jpg" type="image/jpeg">
    <link rel="apple-touch-icon" href="/JYRAC.jpg">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    
    <style>
        :root {
            --primary: #009aa6;
            --primary-light: #00d2e0;
            --primary-dark: #1d8b98;
            --navy: #002b54;
            --navy-light: #0a3d6d;
            --accent: #e67e22;
            --accent-light: #ff9f43;
            --panel-bg: rgba(255, 255, 255, 0.90);
        }
        /* ...中略（既存の共通スタイル）... */
        
        .btn-gioco-launch {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            color: #ffffff;
            padding: 18px 40px;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 15px;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, #1B3A8C 0%, #152E70 100%);
            box-shadow: 0 6px 20px rgba(27, 58, 140, 0.2);
            border: 1px solid rgba(74, 169, 224, 0.3);
        }
        .btn-gioco-launch:hover {
            transform: translate3d(0, -4px, 0);
            box-shadow: 0 12px 30px rgba(27, 58, 140, 0.4);
            border-color: #4AA9E0;
        }
        .info-card-box {
            background: #ffffff;
            border: 1px solid rgba(0, 154, 166, 0.15);
            border-radius: 20px;
            padding: 35px;
            margin-top: 30px;
            box-shadow: 0 4px 20px rgba(0, 43, 84, 0.01);
            text-align: center;
        }
        .info-card-box p {
            color: #4f5e71;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 30px;
            text-align: left;
            line-height: 1.8;
        }
    </style>
</head>
