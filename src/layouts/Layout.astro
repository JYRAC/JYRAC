---
interface Props {
  title: string;
  currentTab: 'news' | 'about' | 'services' | 'governance' | 'sns' | 'contact' | 'gioco'; 
}

const { title, currentTab } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="U3N1SPErYZ6hcrPgWswh8WCyACwLkJXfE7c7QNofrBQ" />
    <meta name="description" content="日本若者防災復興協会（JYRAC）は、若者が主体となり防災・減災・災害復興に取り組むNPO法人です。" />
    <title>{title}</title>
    <link rel="icon" href="/JYRAC.jpg" type="image/jpeg">
    <link rel="apple-touch-icon" href="/JYRAC.jpg">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    
    <style>
        :root {
            --primary: #009aa6;
            --primary-light: #00d2e0;
            --primary-dark: #1d8b98;
            --navy: #002b54;
            --navy-light: #0a3d6d;
            --accent: #e67e22;
            --accent-light: #ff9f43;
            --panel-bg: rgba(255, 255, 255, 0.90);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;
            line-height: 1.8;
            color: #2c3e50;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #e3f6f7 0%, #ffffff 50%, #f4fafb 100%);
            background-attachment: fixed;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(0, 154, 166, 0.01) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(0, 154, 166, 0.01) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
            z-index: -1;
        }

        .crystal-field {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }
        .crystal {
            position: absolute;
            width: 0;
            height: 0;
            border-left: 20px solid transparent;
            border-right: 20px solid transparent;
            border-bottom: 35px solid rgba(0, 154, 166, 0.12);
            filter: drop-shadow(0 4px 10px rgba(0, 210, 224, 0.2));
            transform: translate3d(0, 0, 0);
        }
        .crystal::after {
            content: '';
            position: absolute;
            left: -20px;
            top: 35px;
            width: 0;
            height: 0;
            border-left: 20px solid transparent;
            border-right: 20px solid transparent;
            border-top: 35px solid rgba(0, 43, 84, 0.08);
        }
        .cr-1 { top: 15%; left: 3%; transform: scale(0.7); }
        .cr-2 { top: 75%; left: 6%; transform: scale(1.1); }
        .cr-3 { top: 35%; right: 4%; transform: scale(1.4); border-bottom-color: rgba(230, 126, 34, 0.08); }

        header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 24px 40px;
            border-bottom: 1px solid rgba(0, 154, 166, 0.2);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .brand-zone h1 {
            margin: 0;
            font-size: 22px;
            color: var(--navy);
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .brand-zone h1 span {
            font-size: 10px;
            color: #ffffff;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent) 0%, #d35400 100%);
            padding: 3px 10px;
            border-radius: 20px;
        }
        .subtitle {
            font-size: 10px;
            color: var(--primary-dark);
            font-weight: 700;
            letter-spacing: 1px;
            margin-top: 2px;
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            display: flex;
            gap: 40px;
            position: relative;
            z-index: 10;
        }

        aside {
            width: 280px;
            flex-shrink: 0;
        }
        .side-menu {
            padding: 0;
            margin: 0;
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .menu-btn {
            display: block;
            width: 100%;
            padding: 18px 24px;
            color: var(--navy);
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            background: var(--panel-bg);
            border: 1px solid rgba(0, 154, 166, 0.2);
            border-radius: 14px;
            text-align: left;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 43, 84, 0.02);
            transition: color 0.25s, border-color 0.25s, padding-left 0.25s, background 0.25s;
            box-sizing: border-box;
        }
        .menu-btn::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
            transition: width 0.2s ease;
            z-index: -1;
        }
        .menu-btn:hover {
            color: #ffffff;
            border-color: var(--primary-light);
            padding-left: 30px;
        }
        .menu-btn:hover::before {
            width: 100%;
        }
        .menu-btn.active {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            color: #ffffff;
            border: 1px solid var(--primary-light);
            box-shadow: 0 10px 25px rgba(0, 43, 84, 0.15);
        }

        main {
            flex-grow: 1;
            background: var(--panel-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding: 50px;
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-top: 4px solid var(--primary);
            min-height: 500px;
            box-shadow: 0 20px 50px rgba(0, 43, 84, 0.03);
            border-radius: 24px;
            position: relative;
        }

        main::before {
            content: '';
            position: absolute;
            top: 16px;
            right: 16px;
            width: 16px;
            height: 16px;
            border-top: 2px solid var(--primary-light);
            border-right: 2px solid var(--primary-light);
            pointer-events: none;
        }

        /* 💡 【他ページ崩れ＆二重枠防止】ゲーム画面（/hug-gioco）が直接呼ばれた場合は、外側の白いパネルスタイルを完全無効化 */
        .layout-gioco-mode {
            background: transparent !important;
            border: none !important;
            padding: 0 !important;
            box-shadow: none !important;
        }
        .layout-gioco-mode::before {
            display: none !important;
        }

        footer {
            text-align: center;
            padding: 45px 20px;
            background-color: var(--navy);
            color: rgba(255, 255, 255, 0.7);
            font-size: 13px;
            margin-top: 100px;
            border-top: 5px solid var(--primary-light);
            position: relative;
            z-index: 20;
        }

        .btn-gioco-launch {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            font-family: 'Zen Maru Gothic', sans-serif;
            font-weight: 800;
            border: none;
            cursor: pointer;
            border-radius: 999px;
            padding: 14px 40px;
            font-size: 1.1rem;
            color: #fff;
            background: #2e9e4f;
            box-shadow: 0 6px 0 #1f7d3c, 0 12px 20px rgba(46, 158, 79, 0.25);
            text-decoration: none;
            transition: transform 0.1s, box-shadow 0.1s;
        }
        .btn-gioco-launch:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 #1f7d3c, 0 6px 10px rgba(46, 158, 79, 0.2);
        }

        .info-card-box {
            background: #ffffff;
            border: 1px solid rgba(0, 154, 166, 0.15);
            border-radius: 20px;
            padding: 35px;
            margin-top: 30px;
            box-shadow: 0 4px 20px rgba(0, 43, 84, 0.01);
            text-align: center;
        }
        .info-card-box p {
            color: #4f5e71;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 30px;
            text-align: left;
            line-height: 1.8;
        }

        @media (max-width: 850px) {
            header { padding: 20px; text-align: center; }
            .dashboard-container { flex-direction: column; margin: 20px auto; gap: 24px; }
            aside { width: 100%; }
            .side-menu { display: grid; grid-template-columns: 1fr 1fr; border-radius: 16px; gap: 10px; }
            .menu-btn { text-align: center; border-radius: 10px; padding: 12px 5px; }
            main { padding: 30px 20px; }
            .crystal-field { display: none; }
        }
    </style>
</head>
<body>

<div class="crystal-field">
    <div class="crystal cr-1"></div>
    <div class="crystal cr-2"></div>
    <div class="crystal cr-3"></div>
</div>

<header>
    <div class="header-container">
        <div class="brand-zone">
            <h1>日本若者防災復興協会<span>特定非営利活動法人 設立登記申請中</span></h1>
            <div class="subtitle">Japan Youth Resilience Action Consortium (JYRAC)</div>
        </div>
    </div>
</header>

<div class="dashboard-container">
    <aside>
        <ul class="side-menu">
            <li><a href="/" class={`menu-btn ${currentTab === 'news' ? 'active' : ''}`}>ホーム / 新着情報</a></li>
            <li><a href="/about" class={`menu-btn ${currentTab === 'about' ? 'active' : ''}`}>当法人について</a></li>
            <li><a href="/services" class={`menu-btn ${currentTab === 'services' ? 'active' : ''}`}>事業内容・活動</a></li>
            <li><a href="/gioco" class={`menu-btn ${currentTab === 'gioco' ? 'active' : ''}`}>HUG Gioco (教材)</a></li>
            <li><a href="/governance" class={`menu-btn ${currentTab === 'governance' ? 'active' : ''}`}>情報公開・設立公告</a></li>
            <li><a href="/sns" class={`menu-btn ${currentTab === 'sns' ? 'active' : ''}`}>公式SNS一覧</a></li>
            <li><a href="/contact" class={`menu-btn ${currentTab === 'contact' ? 'active' : ''}`}>お問い合わせ</a></li>
        </ul>
    </aside>

    {/* 💡 【超重要修正】現在のパス（Astro.url.pathname）がゲーム画面「/hug-gioco」に直接一致している場合は、被さっている説明文パネル（currentTab === 'gioco' の中身）をスキップさせて、ゲームの中身（<slot />）を通します */}
    <main id="main-panel" class={Astro.url.pathname.includes('hug-gioco') ? 'layout-gioco-mode' : ''}>
        {currentTab === 'gioco' && !Astro.url.pathname.includes('hug-gioco') ? (
            <div class="content-panel">
                <h2>HUG Gioco — TKB型避難所運営ディスカッションゲーム</h2>
                <div class="info-card-box">
                    <p>「HUG Gioco（グロッコ）」は、TKB（トイレ・キッチン・ベッド）型避難所運営をテーマにした、子どもから大人まで直感的に学べる防災シミュレーションゲームです。</p>
                    <div style="text-align: center; margin: 40px 0;">
                        <a href="/hug-gioco" class="btn-gioco-launch">
                            🚀 ゲームを起動する ➔
                        </a>
                    </div>
                </div>
            </div>
        ) : (
            <slot /> 
        )}
    </main>
</div>

<footer>
    <p>&copy; 2026 日本若者防災復興協会（特定非営利活動法人 設立登記申請中） All Rights Reserved.</p>
</footer>

<script is:inline>
    function runJyracGsapAnimation() {
        if (typeof gsap === "undefined") return;

        if (window.innerWidth > 850) {
            gsap.killTweensOf(".crystal");
            gsap.to(".cr-1", { y: -25, rotation: 360, duration: 12, repeat: -1, yoyo: true, ease: "power1.inOut" });
            gsap.to(".cr-2", { y: 20, rotation: -360, duration: 15, repeat: -1, yoyo: true, ease: "power1.inOut" });
            gsap.to(".cr-3", { y: -30, rotation: 180, duration: 10, repeat: -1, yoyo: true, ease: "power1.inOut" });

            const menuButtons = document.querySelectorAll('.side-menu a');
            menuButtons.forEach((btn, index) => {
                gsap.to(btn, { y: -5, duration: 5, repeat: -1, yoyo: true, ease: "power1.inOut", delay: index * 0.2 });
                btn.addEventListener('mouseenter', () => gsap.to(btn, { y: -2, scale: 1.03, duration: 0.3, ease: "power2.out" }));
                btn.addEventListener('mouseleave', () => gsap.to(btn, { scale: 1, duration: 0.3, ease: "power2.inOut" }));
            });
        }
    }

    document.addEventListener("DOMContentLoaded", runJyracGsapAnimation);
    document.addEventListener("astro:page-load", runJyracGsapAnimation);
</script>
</body>
</html>
